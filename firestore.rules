rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users: any authenticated user can read any user doc
    // (needed for admin role checks + profile lookups)
    // Only the user themselves or an admin can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Careers: anyone can read, only admins can write
    match /careers/{careerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin requests: anyone authenticated can create their own; only admins can read/update
    match /admin_requests/{requestId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }
  }
}

