rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users: any authenticated user can read any user doc
    match /users/{userId} {
      allow read: if request.auth != null;
      // Users can only create their own document if they set their role to user
      allow create: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.role == "user";
      // Users can only update their own document if they don't change their role
      allow update: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.role == resource.data.role;
      // Admins can manage all users
      allow delete, update, create: if isAdmin();
    }

    // Careers: anyone can read, only admins can write
    match /careers/{careerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin requests: Users can only create requests for their own email
    match /admin_requests/{requestId} {
      allow create: if request.auth != null && request.resource.data.email == request.auth.token.email;
      allow read, update, delete: if isAdmin();
    }

    // Applications: Users can read/write their own applications, admins can read/write all
    match /applications/{appId} {
      // User must be authenticated
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Allow user to read/update/delete their own application, or admins to read/update/delete all
      allow read, update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}

